{
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": [
      "/_next/*",
      "/_next/static/*",
      "/_next/static/chunks/*",
      "/_next/static/media/*",
      "/_next/static/*/_buildManifest.js",
      "/_next/static/*/_ssgManifest.js",
      "/_next/static/*/_clientMiddlewareManifest.json",
      "/images/*",
      "/*.pdf",
      "/*.png",
      "/*.ico",
      "/*.svg"
    ]
  },
  "routes": [
    {
      "route": "/Resume_Rutao_Luo.pdf",
      "headers": {
        "Content-Type": "application/pdf",
        "Content-Disposition": "attachment; filename=\"Resume_Rutao_Luo.pdf\""
      }
    }
  ],
  "responseOverrides": {
    "404": {
      "rewrite": "/404/index.html",
      "statusCode": 404
    }
  },
  "globalHeaders": {
    "X-Content-Type-Options": "nosniff",
    "X-Frame-Options": "SAMEORIGIN",
    "X-XSS-Protection": "1; mode=block",
    "Referrer-Policy": "strict-origin-when-cross-origin",
    "Permissions-Policy": "camera=(), microphone=(), geolocation=()"
  },
  "mimeTypes": {
    ".pdf": "application/pdf"
  }
}
